    <script>
        // Stimulus Controllers
        const application = Stimulus.Application.start();

        // Header Controller
        application.register("header", class extends Stimulus.Controller {
            static targets = ["mobileMenu"];

            toggleMobile() {
                this.mobileMenuTarget.classList.toggle("hidden");
            }
        });

        // Search Controller
        application.register("search", class extends Stimulus.Controller {
            static targets = ["input"];

            connect() {
                this.inputTarget.addEventListener("keypress", (e) => {
                    if (e.key === "Enter") {
                        this.search();
                    }
                });
            }

            search() {
                const query = this.inputTarget.value;
                console.log("Searching for:", query);
                // Implement search functionality
            }
        });

        // Products Controller
        application.register("products", class extends Stimulus.Controller {
            addToCart(event) {
                const productCard = event.currentTarget.closest('.group');
                const productName = productCard.querySelector('h3').textContent;
                console.log("Added to cart:", productName);
                
                // Add visual feedback
                event.currentTarget.innerHTML = '<i class="fas fa-check"></i>';
                event.currentTarget.classList.add('bg-green-600');
                
                setTimeout(() => {
                    event.currentTarget.innerHTML = '<i class="fas fa-cart-plus"></i>';
                    event.currentTarget.classList.remove('bg-green-600');
                    event.currentTarget.classList.add('bg-brand-red');
                }, 1000);
            }
        });

        // Teams Controller
        application.register("teams", class extends Stimulus.Controller {
            selectTeam(event) {
                const team = event.currentTarget.dataset.team;
                console.log("Selected team:", team);
            }

            selectLeague(event) {
                const league = event.currentTarget.dataset.league;
                console.log("Selected league:", league);
            }
        });

        // Cart Controller
        application.register("cart", class extends Stimulus.Controller {
            connect() {
                this.count = 0;
                this.updateDisplay();
            }

            addItem() {
                this.count++;
                this.updateDisplay();
            }

            updateDisplay() {
                const badge = this.element.querySelector("span");
                if (badge) {
                    badge.textContent = this.count;
                }
            }
        });

        // Hero Controller
        application.register("hero", class extends Stimulus.Controller {
            connect() {
                console.log("Hero section loaded");
            }
        });

        // Add event listeners for product buttons
        document.addEventListener('DOMContentLoaded', function() {
            const addToCartButtons = document.querySelectorAll('.bg-brand-red');
            addToCartButtons.forEach(button => {
                if (button.querySelector('.fa-cart-plus')) {
                    button.addEventListener('click', function(e) {
                        e.preventDefault();
                        const productCard = this.closest('.group');
                        const productName = productCard.querySelector('h3').textContent;
                        console.log("Added to cart:", productName);
                        
                        // Visual feedback
                        this.innerHTML = '<i class="fas fa-check"></i>';
                        this.classList.remove('bg-brand-red');
                        this.classList.add('bg-green-600');
                        
                        setTimeout(() => {
                            this.innerHTML = '<i class="fas fa-cart-plus"></i>';
                            this.classList.remove('bg-green-600');
                            this.classList.add('bg-brand-red');
                        }, 1000);
                    });
                }
            });
        });

        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Dropshipping Controller
        application.register("dropshipping", class extends Stimulus.Controller {
            connect() {
                console.log("Dropshipping section loaded");
                this.animateOnScroll();
            }

            animateOnScroll() {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('animate-fade-in');
                        }
                    });
                });

                const elements = this.element.querySelectorAll('.bg-white');
                elements.forEach(el => observer.observe(el));
            }
        });
    </script>
