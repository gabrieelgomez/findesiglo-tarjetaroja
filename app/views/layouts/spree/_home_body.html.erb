<body class="bg-white text-gray-900 font-sans">
    <%
        home_store = (defined?(current_store) && current_store.present?) ? current_store : Spree::Store.default
        home_currency = (defined?(current_currency) && current_currency.present?) ? current_currency : home_store.default_currency
        home_products_pool = Spree::Product
            .for_store(home_store)
            .published
            .not_discontinued
            .includes(:taxons, :images, master: :prices)
            .to_a
            .select(&:available?)

        featured_products = home_products_pool.sample(4)
        remaining_products = home_products_pool.reject { |product| featured_products.any? { |featured| featured.id == product.id } }
        league_products = remaining_products.sample(4)

        if league_products.size < 4
            fallback_products = home_products_pool.reject { |product| league_products.any? { |league| league.id == product.id } }
            league_products = (league_products + fallback_products.sample(4 - league_products.size)).uniq { |product| product.id }.first(4)
        end
    %>
    <!-- Hero Section -->
    <section class="relative bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 py-20 lg:py-32 overflow-hidden" data-controller="hero">
        <!-- Background Pattern -->
        <div class="absolute inset-0 opacity-10">
            <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,<svg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"><g fill="none" fill-rule="evenodd"><g fill="%23ffffff" fill-opacity="0.1"><circle cx="30" cy="30" r="2"/></g></svg>');"></div>
        </div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
            <div class="text-center">
                <!-- Logo Principal -->
                <div class="mb-8">
                    <img src="https://hebbkx1anhila5yf.public.blob.vercel-storage.com/IMG_5528.PNG-yBIkBJtv6VLL7DT7bmQgEF7Ifgm35x.png" alt="Tarjeta Roja" class="h-32 lg:h-40 mx-auto">
                </div>
                
                <!-- Título Principal -->
                <h1 class="text-4xl lg:text-6xl font-bold text-white mb-6 leading-tight">
                    Las mejores <span class="text-red-400">camisas de fútbol</span><br>
                    en Venezuela
                </h1>
                
                <!-- Subtítulo -->
                <p class="text-xl lg:text-2xl text-gray-300 mb-8 max-w-3xl mx-auto">
                    Precios desde <span class="font-bold text-red-400">$15 USD</span> • Mayor y Detal • Dropshipping • Envíos a todo el país
                </p>
                
                <!-- Botones CTA -->
                <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
                    <a href="/products" class="bg-red-600 text-white px-8 py-4 rounded-full font-semibold hover:bg-red-700 transform hover:scale-105 transition-all duration-200 shadow-lg text-lg">
                        <i class="fas fa-tshirt mr-2"></i>
                        Ver Catálogo Completo
                    </a>
                    <a target="_blank" href="https://wa.me/584224292286?text=Hola, quiero comprar una camiseta de fútbol vengo desde la página web..." class="border-2 border-red-400 text-red-400 px-8 py-4 rounded-full font-semibold hover:bg-red-400 hover:text-white transition-all duration-200 text-lg">
                        <i class="fab fa-whatsapp mr-2"></i>
                        Contactar WhatsApp
                    </a>
                </div>
                
                <!-- Stats -->
                <div class="grid grid-cols-3 gap-8 max-w-2xl mx-auto">
                    <div class="text-center">
                        <div class="text-3xl lg:text-4xl font-bold text-red-400 mb-2">500+</div>
                        <div class="text-gray-300">Productos</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl lg:text-4xl font-bold text-red-400 mb-2">50+</div>
                        <div class="text-gray-300">Equipos</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl lg:text-4xl font-bold text-red-400 mb-2">24/7</div>
                        <div class="text-gray-300">Soporte</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Banner Promocional -->
    <section class="bg-red-600 py-4">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center text-white">
                <p class="text-lg font-semibold">
                    🔥 OFERTA ESPECIAL: Para compras mayores a 24 unidades, $14.5 USD por unidad 🔥
                </p>
            </div>
        </div>
    </section>

    <!-- Productos Destacados -->
    <section id="productos" class="py-20 bg-white" data-controller="products">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl lg:text-4xl font-bold text-brand-dark mb-4">
                    Productos Destacados
                </h2>
                <p class="text-xl text-gray-600">Las camisas más vendidas de la temporada</p>
            </div>

            <% if featured_products.any? %>
                <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-4 gap-6">
                    <% featured_products.each do |product| %>
                        <div class="group bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 overflow-hidden">
                            <a href="<%= spree.product_path(product) %>" class="block">
                                <div class="aspect-square bg-gradient-to-br from-gray-50 to-white p-4">
                                    <% if product.default_image.present? && product.default_image.attached? %>
                                        <% featured_variant_options = spree_image_variant_options(resize_to_fill: [400, 400]) %>
                                        <%= image_tag main_app.cdn_image_url(product.default_image.variant(featured_variant_options)), width: 400, height: 400, loading: :lazy, decoding: "async", alt: product.name, class: "w-full h-full object-contain" %>
                                    <% else %>
                                        <img src="/placeholder.svg?height=200&width=200&text=Sin+imagen" alt="<%= product.name %>" class="w-full h-full object-contain">
                                    <% end %>
                                </div>
                                <div class="p-4">
                                    <h3 class="font-bold text-lg text-brand-dark mb-1 line-clamp-1"><%= product.name %></h3>
                                    <p class="text-gray-600 text-sm mb-2 line-clamp-1"><%= product.taxons.first&.name || "Producto disponible" %></p>
                                    <div class="flex justify-between items-center">
                                        <span class="text-brand-red font-bold text-lg"><%= product.price_in(home_currency).display_amount %></span>
                                        <span class="inline-flex items-center bg-brand-red text-white px-3 py-1 rounded-full text-sm hover:bg-red-700 transition-colors">
                                            <i class="fas fa-eye mr-1"></i>
                                            Ver
                                        </span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    <% end %>
                </div>
            <% else %>
                <div class="text-center text-gray-600">
                    No hay productos disponibles para mostrar en este momento.
                </div>
            <% end %>

            <div class="text-center mt-12">
                <a href="/products" class="bg-brand-red text-white px-8 py-3 rounded-full font-semibold hover:bg-red-700 transition-colors">
                    Ver Todos los Productos
                </a>
