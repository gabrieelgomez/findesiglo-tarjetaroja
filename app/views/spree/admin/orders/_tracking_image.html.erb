<div class="card mb-3">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-3">
      <div>
        <h6 class="card-title mb-1">
          <i class="fas fa-image text-primary me-2"></i>
          Imagen de Tracking del Pedido
        </h6>
        <p class="card-text text-muted mb-0">
          Sube una foto o imagen del tracking del pedido
        </p>
      </div>
    </div>

    <% if @order.tracking_image.attached? %>
      <div class="mb-3">
        <div class="d-flex align-items-center gap-3 mb-2">
          <div class="flex-grow-1">
            <p class="mb-0 text-muted small">Imagen actual:</p>
          </div>
          <%= link_to spree.remove_tracking_image_admin_order_path(@order),
              class: "btn btn-sm btn-outline-danger",
              data: { 
                turbo_method: :delete, 
                turbo_confirm: "¿Estás seguro de que quieres eliminar esta imagen?" 
              } do %>
            <i class="fas fa-trash"></i> Eliminar
          <% end %>
        </div>
        <div class="border rounded p-2 bg-light">
          <%= image_tag @order.tracking_image.url, class: "img-fluid rounded", style: "max-height: 400px; width: auto;" if @order.tracking_image.attached? %>
        </div>
      </div>
    <% end %>

    <%= form_with url: spree.upload_tracking_image_admin_order_path(@order),
        method: :post,
        multipart: true,
        data: { turbo_frame: "_top" },
        id: "tracking-image-form",
        class: "mt-3" do |f| %>

      <div id="tracking-drop-zone"
           class="tracking-drop-zone mb-3"
           style="border: 2px dashed #cbd5e1; border-radius: 12px; padding: 32px 16px; text-align: center; cursor: pointer; transition: all 0.2s ease; background: #f8fafc;">
        <div style="pointer-events: none;">
          <i class="fas fa-paste text-primary" style="font-size: 2rem; margin-bottom: 8px;"></i>
          <p class="mb-1 fw-semibold text-dark">Pega una captura de pantalla o arrastra una imagen aquí</p>
          <p class="text-muted small mb-0">
            También puedes <span class="text-primary fw-semibold">hacer clic para seleccionar un archivo</span>
          </p>
          <p class="text-muted small mb-0 mt-1">
            <i class="fas fa-keyboard me-1"></i> Ctrl+V / Cmd+V para pegar desde el portapapeles
          </p>
          <p class="text-muted small mb-0 mt-1">
            Formatos: JPG, PNG, HEIC — Máx. 10MB
          </p>
        </div>
      </div>

      <%= file_field_tag :tracking_image,
          accept: "image/*",
          class: "d-none",
          id: "tracking-file-input" %>

      <div id="tracking-preview" class="d-none mb-3">
        <div class="border rounded p-3 bg-light d-flex align-items-center gap-3">
          <img id="tracking-preview-image" src="" alt="Vista previa" class="rounded" style="max-height: 120px; max-width: 200px; object-fit: contain;">
          <div class="flex-grow-1">
            <p class="mb-1 fw-semibold text-dark small" id="tracking-preview-name"></p>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="tracking-remove-preview">
              <i class="fas fa-times me-1"></i> Cambiar imagen
            </button>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2">
        <%= submit_tag @order.tracking_image.attached? ? "Actualizar Imagen" : "Subir Imagen", 
            class: "btn btn-primary d-flex align-items-center gap-2" %>
        <% if @order.tracking_image.attached? %>
          <%= link_to spree.send_tracking_whatsapp_admin_order_path(@order),
              class: "btn btn-success d-flex align-items-center gap-2",
              data: { 
                turbo_method: :post,
                turbo_confirm: "¿Enviar la imagen de tracking por WhatsApp al cliente?" 
              } do %>
            <i class="fab fa-whatsapp"></i>
            Enviar tracking por WhatsApp
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<style>
  .tracking-drop-zone:hover,
  .tracking-drop-zone.drag-over {
    border-color: #3b82f6 !important;
    background: #eff6ff !important;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }
</style>

<script>
  (function() {
    const dropZone = document.getElementById('tracking-drop-zone');
    const fileInput = document.getElementById('tracking-file-input');
    const preview = document.getElementById('tracking-preview');
    const previewImage = document.getElementById('tracking-preview-image');
    const previewName = document.getElementById('tracking-preview-name');
    const removeBtn = document.getElementById('tracking-remove-preview');

    if (!dropZone || !fileInput) return;

    function attachFile(file) {
      if (file.size > 10 * 1024 * 1024) {
        alert('La imagen excede el tamaño máximo de 10MB');
        return;
      }
      const dt = new DataTransfer();
      dt.items.add(file);
      fileInput.files = dt.files;
      showPreview(file);
    }

    function showPreview(file) {
      const reader = new FileReader();
      reader.onload = function(e) {
        previewImage.src = e.target.result;
        previewName.textContent = file.name + ' (' + (file.size / (1024 * 1024)).toFixed(2) + ' MB)';
        preview.classList.remove('d-none');
        dropZone.classList.add('d-none');
      };
      reader.readAsDataURL(file);
    }

    function removePreview() {
      fileInput.value = '';
      preview.classList.add('d-none');
      dropZone.classList.remove('d-none');
    }

    document.addEventListener('paste', function(e) {
      var items = e.clipboardData && e.clipboardData.items;
      if (!items) return;
      for (var i = 0; i < items.length; i++) {
        if (items[i].type.indexOf('image/') === 0) {
          e.preventDefault();
          var file = items[i].getAsFile();
          if (file) attachFile(file);
          return;
        }
      }
    });

    dropZone.addEventListener('click', function() {
      fileInput.click();
    });

    fileInput.addEventListener('change', function() {
      var file = fileInput.files[0];
      if (file && file.type.indexOf('image/') === 0) {
        showPreview(file);
      }
    });

    dropZone.addEventListener('drop', function(e) {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      var files = e.dataTransfer && e.dataTransfer.files;
      if (files && files.length > 0 && files[0].type.indexOf('image/') === 0) {
        attachFile(files[0]);
      }
    });

    dropZone.addEventListener('dragover', function(e) {
      e.preventDefault();
      dropZone.classList.add('drag-over');
    });

    dropZone.addEventListener('dragleave', function(e) {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
    });

    removeBtn.addEventListener('click', removePreview);
  })();
</script>