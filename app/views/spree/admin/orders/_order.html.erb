<tr id="<%= dom_id(order) %>" data-controller="row-link">
  <td class="p-0" style="white-space:nowrap">
    <%= link_to order.number, spree.edit_admin_order_path(order), class: 'font-weight-bolder d-block p-2 px-3 text-decoration-none', data: { 'turbo-frame': '_top', row_link_target: :link } %>
  </td>
  <td class="cursor-pointer" style="white-space:nowrap" data-action="click->row-link#openLink">
    <%= local_time_ago(order.completed? ? order.completed_at : order.created_at, format: '%b %e, %Y %l:%M%P', class: 'with-tip') %>
  </td>
  <td class="d-customer cursor-pointer" data-action="click->row-link#openLink">
    <%= render 'spree/admin/orders/customer_summary', order: order %>
  </td>
  <td class="cursor-pointer" style="white-space:nowrap" data-action="click->row-link#openLink">
    <%= order_payment_state(order) %>
  </td>
  <td class="cursor-pointer" style="white-space:nowrap" data-action="click->row-link#openLink">
    <%= shipment_state(order.shipments.first&.state || order.shipment_state) %>
  </td>
  <td class="text-center" style="white-space:nowrap">
    <% if order.completed? && !order.canceled? %>
      <%
        raw_st = order.shipments.first&.state || order.shipment_state || 'pending'
        norm_st = %w(backorder partial).include?(raw_st) ? 'pending' : raw_st

        next_map = {
          'pending'   => { target: 'apartado',  label: 'Apartar',  color: '#7C3AED', bg: '#EDE9FE' },
          'ready'     => { target: 'apartado',  label: 'Apartar',  color: '#7C3AED', bg: '#EDE9FE' },
          'apartado'  => { target: 'fabricado', label: 'Fabricar', color: '#D97706', bg: '#FEF3C7' },
          'fabricado' => { target: 'empacado',  label: 'Empacar',  color: '#059669', bg: '#D1FAE5' },
          'empacado'  => { target: 'shipped',   label: 'Enviar',   color: '#047857', bg: '#A7F3D0' },
        }
        nxt = next_map[norm_st]
      %>
      <% if nxt %>
        <%= button_to update_shipment_state_admin_order_path(order),
              params: { shipment_state: nxt[:target], source: 'list' },
              method: :post,
              form: { data: { turbo_confirm: "¿Marcar #{order.number} como #{nxt[:label]}?" } },
              class: "btn btn-sm text-decoration-none border-0",
              style: "background:#{nxt[:bg]};color:#{nxt[:color]};font-size:0.7rem;font-weight:700;padding:3px 8px;border-radius:6px;border:1px solid #{nxt[:color]}33;white-space:nowrap;cursor:pointer;" do %>
          <%= nxt[:label] %> →
        <% end %>
      <% else %>
        <span style="color:#059669;font-size:0.7rem">✓</span>
      <% end %>
    <% else %>
      <span style="color:#9CA3AF;font-size:0.7rem">—</span>
    <% end %>
  </td>
  <td class="text-right cursor-pointer" style="white-space:nowrap" data-action="click->row-link#openLink">
    <%= pluralize(order.item_count, 'item') %>
  </td>
  <td class="text-right cursor-pointer" style="white-space:nowrap" data-action="click->row-link#openLink">
    <%= order.display_total.to_html %>
  </td>
</tr>
